          "format": "table",
          "instant": true,
          "legendFormat": "",
          "refId": "F"
        }
      ],
      "title": "Channel Details",
      "transformations": [
        {
          "id": "merge",
          "options": {}
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "__name__": true,
              "job": false,
              "instance": false
            },
            "renameByName": {
              "Value #A": "Local Balance (CKB)",
              "Value #B": "Remote Balance (CKB)",
              "Value #C": "Enabled",
              "Value #D": "Peer Online",
              "Value #E": "Last Seen",
              "Value #F": "Stale Duration"
            },
            "indexByName": {
              "node_name": 0,
              "channel_id": 1,
              "peer_id": 2,
              "Local Balance (CKB)": 3,
              "Remote Balance (CKB)": 4,
              "Enabled": 5,
              "Peer Online": 6,
              "Last Seen": 7,
              "Stale Duration": 8
            }
