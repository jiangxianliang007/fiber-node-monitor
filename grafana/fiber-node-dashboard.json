    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "displayMode": "auto",
            "inspect": false
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Last Seen"
            },
            "properties": [
              {
                "id": "unit",
                "value": "dateTimeAsLocal"
              },
              {
                "id": "custom.width",
                "value": 180
              },
              {
                "id": "description",
                "value": "Timestamp of the last channel state change (balance change, TLC activity, enabled/disabled toggle, etc.). Only updates when the channel fingerprint actually changes"
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Stale Duration"
            },
            "properties": [
              {
                "id": "unit",
                "value": "s"
              },
              {
                "id": "custom.width",
                "value": 150
              },
              {
                "id": "description",
                "value": "How long (in seconds) since the last channel state change: time() - last_seen. A large value means the channel has been idle with no state changes for a long time"
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Enabled"
            },
            "properties": [
              {
                "id": "custom.width",
                "value": 80
              },
              {
                "id": "mappings",
                "value": [
                  {
                    "options": {
                      "0": {
                        "text": "❌"
                      },
                      "1": {
                        "text": "✅"
                      }
                    },
                    "type": "value"
                  }
                ]
              },
              {
                "id": "description",
                "value": "Whether the channel is enabled (✅) or disabled (❌)"
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Channel Online"
            },
            "properties": [
              {
                "id": "custom.width",
                "value": 100
              },
              {
                "id": "mappings",
                "value": [
                  {
                    "options": {
                      "0": {
                        "text": "❌ Not Online"
                      },
                      "1": {
                        "text": "✅ Online"
                      }
                    },
                    "type": "value"
                  }
                ]
              },
              {
                "id": "description",
                "value": "Whether the channel is truly usable (CHANNEL_READY + enabled + peer online). 1=usable, 0=not usable"
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Local Balance (CKB)"
            },
            "properties": [
              {
                "id": "decimals",
                "value": 2
              },
              {
                "id": "custom.width",
                "value": 150
              },
              {
                "id": "description",
                "value": "Your node's balance in this channel, in CKB units"
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Remote Balance (CKB)"
            },
            "properties": [
              {
                "id": "decimals",
                "value": 2
              },
              {
                "id": "custom.width",
                "value": 160
              },
              {
                "id": "description",
                "value": "The remote peer's balance in this channel, in CKB units"
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Channel ID"
            },
            "properties": [
              {
                "id": "custom.width",
                "value": 200
              },
              {
                "id": "description",
                "value": "Unique identifier of the payment channel"
              }
            ]
          },
          {
