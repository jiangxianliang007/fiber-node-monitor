            "matcher": {"id": "byName", "options": "Last Seen"},
            "properties": [
              {"id": "unit", "value": "dateTimeAsLocal"},
              {"id": "custom.width", "value": 180}
            ]
          },
          {
            "matcher": {"id": "byName", "options": "Stale Duration"},
