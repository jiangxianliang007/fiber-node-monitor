            "properties": [
              {
                "id": "custom.width",
                "value": 200
              },
              {
                "id": "description",
                "value": "The remote peer's node ID for this channel"
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Node"
            },
            "properties": [
              {
                "id": "description",
